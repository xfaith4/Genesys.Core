                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0"
                                                    Background="#0F161B"
                                                    BorderBrush="{StaticResource BrushLine}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="4">
                                                <TextBox x:Name="TxtQualityCorrelation"
                                                         Style="{StaticResource TxtBase}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         Margin="2"/>
                                            </Border>
                                            <Border Grid.Row="2"
                                                    Background="#0F161B"
                                                    BorderBrush="{StaticResource BrushLine}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="2">
                                                <DataGrid x:Name="DgLowScoreTopics" Style="{StaticResource DgBase}" Margin="2">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Topic" Binding="{Binding TopicName}" Width="*" SortMemberPath="TopicName"/>
                                                        <DataGridTextColumn Header="Hits" Binding="{Binding TopicHits}" Width="55" SortMemberPath="TopicHits"/>
                                                        <DataGridTextColumn Header="Convs" Binding="{Binding ConversationCount}" Width="55" SortMemberPath="ConversationCount"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Run Console" Foreground="{StaticResource BrushText}">
                                <Grid Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="150"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Style="{StaticResource SectionCard}"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="RUN TELEMETRY"
                                                           Style="{StaticResource LblSection}"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                <Border Style="{StaticResource BadgeBase}">
                                                    <TextBlock x:Name="TxtConsoleStatus"
                                                               Text="Idle"
                                                               Foreground="{StaticResource BrushYellow}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <Button x:Name="BtnCopyDiagnostics" Grid.Column="1"
                                                    Content="Copy Diagnostics"
                                                    Style="{StaticResource BtnBase}"
                                                    Height="30"
                                                    Width="144"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Background="#0F161B"
                                            BorderBrush="{StaticResource BrushLine}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="2"
                                            Margin="0,0,0,10">
                                        <DataGrid x:Name="DgRunEvents" Style="{StaticResource DgBase}" Margin="2">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding timestamp}" Width="170"/>
                                                <DataGridTextColumn Header="Level" Binding="{Binding level}" Width="70"/>
                                                <DataGridTextColumn Header="Message" Binding="{Binding message}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <TextBlock Grid.Row="2"
                                               Text="DIAGNOSTICS OUTPUT"
                                               Style="{StaticResource LblSection}"
                                               Margin="0,0,0,6"/>

                                    <Border Grid.Row="3"
                                            Background="#0F161B"
                                            BorderBrush="{StaticResource BrushLine}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="4">
                                        <TextBox x:Name="TxtDiagnostics"
                                                 Style="{StaticResource TxtBase}"
                                                 IsReadOnly="True"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 FontSize="11"
                                                 TextWrapping="NoWrap"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <StatusBar Grid.Row="2">
                    <StatusBarItem>
                        <TextBlock x:Name="TxtStatusMain"
                                   Text="Ready"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="11"/>
                    </StatusBarItem>
                    <Separator/>
                    <StatusBarItem HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtStatusRight"
                                   Text=""
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="11"/>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </Border>
    </Grid>
</Window>
