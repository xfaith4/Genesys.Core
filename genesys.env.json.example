{
  "_notes": {
    "description": "Genesys Core persistent configuration. Copy this file to 'genesys.env.json' to persist your region. Credentials should NOT be stored here — use environment variables instead.",
    "envVars": {
      "GENESYS_CLIENT_ID":     "Your Genesys Cloud OAuth Client ID (Client Credentials grant).",
      "GENESYS_CLIENT_SECRET": "Your Genesys Cloud OAuth Client Secret. Never commit this value.",
      "GENESYS_BEARER_TOKEN":  "Optional: pre-obtained bearer token. Bypasses the OAuth flow entirely when set."
    },
    "regions": [
      "mypurecloud.com",
      "mypurecloud.com.au",
      "mypurecloud.de",
      "mypurecloud.ie",
      "mypurecloud.jp",
      "mypurecloud.ca",
      "usw2.pure.cloud",
      "euw2.pure.cloud",
      "apne1.pure.cloud",
      "apne2.pure.cloud",
      "aps1.pure.cloud",
      "use2.us-gov-pure.cloud"
    ]
  },
  "region": "mypurecloud.com"
}
